# Bastion env config — copy to .env and fill in.
# .env is git-ignored; never commit credentials.

# Postgres connection string (required)
BASTION_DB_DSN=postgresql://bastion:bastion@localhost:5432/bastion

# Where raw artifact blobs are stored (required; will be created if absent)
BASTION_BLOB_ROOT=./blobs

# HTTP client tuning (optional)
BASTION_DEFAULT_TIMEOUT=30
BASTION_MAX_RETRIES=3
BASTION_HTTP2=0

# User-Agent override (optional)
BASTION_USER_AGENT=BastionResearchBot/0.1 (+contact: ops@silverpot.in)
