    "design_notes": [
      "30 SKUs across 6 stock heads. The 80/20 of cost and operational risk in Eastern Ladakh sustainment.",
      "Terrain-class multipliers follow publicly known Indian Army doctrine: Plains, HA (>=9000ft), SHA (>=12000ft), ECC (Siachen-class, glacier).",
      "All AOI posts fall into HA, SHA, or ECC bands. Plains baseline is included for reference only.",
      "Per-soldier-per-day consumption rates are illustrative central estimates consistent with publicly reported figures.",
      "Real Army scales of issue are restricted; the demo does not claim to reproduce them.",
      "Stock heads mirror ASC/AOC organizational structure (publicly documented).",
      "Critical to a Lt Gen: kerosene burn at SHA is the dominant SHA consumable. Get this right or nothing else looks credible."
    ],
    "altitude_bands_to_terrain_class_mapping": {
      "low (<3500m)": "HA",
      "medium (3500-4500m)": "HA_to_SHA_boundary",
      "high (4500-5000m)": "SHA",
      "extreme (>5000m)": "SHA_to_ECC"
    },
    "post_to_terrain_class": {
      "POST-001": "ECC",
      "POST-002": "SHA",
      "POST-003": "SHA",
      "POST-004": "SHA",
      "POST-005": "SHA",
      "POST-006": "SHA",
      "POST-007": "SHA",
      "POST-008": "SHA",
      "POST-009": "SHA",
      "POST-010": "SHA",
      "POST-011": "SHA",
      "POST-012": "HA_extreme_cold",
      "POST-013": "HA",
      "POST-014": "SHA",
      "POST-015": "ECC"
    },
    "criticality_tiers": {
      "T1": "Life-safety. Stockout means casualties. e.g. oxygen, kerosene at SHA in winter, IV fluids.",
      "T2": "Mission-critical. Stockout degrades operational capability. e.g. ammunition at frontline posts, ATF for helo ops.",
      "T3": "Comfort/sustainment. Stockout degrades morale/efficiency but not immediate capability. e.g. fresh meat, batteries for non-comms.",
      "T4": "Routine. Stockout creates inconvenience. e.g. some general stores."
    },
    "consumption_units": {
      "rations": "kg or units per soldier per day",
      "pol": "litres per soldier per day OR per vehicle per day OR per generator per day (specified per SKU)",
      "ammunition": "rounds per soldier per day baseline (peacetime training scale; combat scales differ wildly)",
      "medical": "units per 100 soldiers per month",
      "clothing": "set replacements per soldier per year (wear-out rate)",
      "general": "varies by SKU"
    },
    "provenance_grading": {
      "A": "SKU exists in public Army inventory documentation (CAG, Lok Sabha QA, MoD annual reports, manufacturer specs).",
      "B": "SKU type/category exists publicly; specific consumption rate is illustrative.",
      "C": "SKU is illustrative for demo purposes; would be a generic stand-in for several real items."
    }
  },

