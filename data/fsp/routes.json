    "model_type": "hybrid_segmented_strategic_simple_tactical",
    "design_notes": [
      "Segments are the base layer where closure events attach.",
      "Edges are the derived layer that the optimizer (Wk12) reasons over.",
      "Lineage chain: segment closure -> edge availability -> resupply plan feasibility.",
      "Strategic LoCs (Zoji La / Manali / Air bridge) are fully segmented at every pass/chokepoint.",
      "Tactical post-feeder routes are single-segment edges for design economy.",
      "Air edges are typed separately with distinct cost/capacity/weather profiles."
    ],
    "cost_units": "INR_per_tonne_baseline_road_road=1x",
    "transit_time_units": "hours_one_way_typical_no_disruption",
    "altitude_unit": "metres_amsl",
    "provenance_notes": {
      "pass_altitudes": "All altitudes from public sources (Wikipedia, BRO publications, OSM). Verified within +/- 50m tolerance.",
      "distances": "Approximate road distances from public mapping data; not surveyed.",
      "seasonal_patterns": "Modelled on publicly reported multi-year closure patterns from BRO bulletins and news archives.",
      "transit_times": "Illustrative baselines consistent with published convoy timings and BRO maintenance schedules."
    }
  },

